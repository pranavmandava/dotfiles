{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.5",
        "mode": "full-access",
        "reasoning_effort": "low"
      },
      "type": "registry"
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "acceptEdits"
      },
      "type": "registry"
    },
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {}
    },
    "dock": "right",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-thinking",
    },
  },
  "relative_line_numbers": "enabled",
  "helix_mode": true,
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "terminal": {
    "font_family": "RecMonoLinear Nerd Font",
  },
  "context_servers": {
    "react-grab-mcp": {
      "source": "custom",
      "command": "npx",
      "args": [
        "-y",
        "@react-grab/mcp",
        "--stdio"
      ],
      "env": {}
    }
  },
}
